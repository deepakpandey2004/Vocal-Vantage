# ============================================================
# Vocal Vantage — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit your real .env file.
# ============================================================

# ----- App -----
APP_NAME=Vocal Vantage
ENVIRONMENT=development          # development | production
DEBUG=true
SECRET_KEY=replace-with-a-long-random-string

# ----- Database -----
# Local SQLite (default, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./vocal_vantage.db
# Production PostgreSQL (Render gives you this URL):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vocal_vantage

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ----- JWT / Auth -----
JWT_SECRET_KEY=replace-with-another-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----- AI providers -----
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Set to true to run the whole pipeline with deterministic mock data
# (no API keys / no cost). Great for local dev and demos.
AI_MOCK_MODE=true

# ----- Uploads -----
MAX_UPLOAD_MB=25
ALLOWED_AUDIO_EXTENSIONS=mp3,wav,m4a,webm,ogg,flac,mp4,mpeg,mpga

# ----- Rate limiting -----
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# ----- CORS -----
CORS_ORIGINS=*
